# ── Database ──
DATABASE_URL=postgresql://pfs:CHANGE_ME@localhost:5432/personal_finance
POSTGRES_DB=personal_finance
POSTGRES_USER=pfs
POSTGRES_PASSWORD=CHANGE_ME

# ── SEC EDGAR ──
# REQUIRED: SEC needs a real email for rate-limit compliance
SEC_USER_AGENT=PersonalFinanceApp your_email@example.com

# ── Alpha Vantage (optional, fallback data source) ──
ALPHA_VANTAGE_KEY=

# ── FRED (optional, for risk-free rate etc.) ──
FRED_API_KEY=

# ── Paths ──
DATA_DIR=/opt/pfs/data

# ── Tailscale ──
# Streamlit binds to this IP (Tailscale only, no public access)
TAILSCALE_IP=100.106.13.112

# ── App ──
LOG_LEVEL=INFO
