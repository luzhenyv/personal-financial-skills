# ── Data Server Environment ──
# Copy to .env.data-server and fill in values.
# Used by: deploy/docker/docker-compose.data.yml

# ── PostgreSQL ──
POSTGRES_DB=personal_finance
POSTGRES_USER=pfs
PFS_DB_PASSWORD=CHANGE_ME

# ── Network ──
# Bind to Tailscale IP for remote access, or 127.0.0.1 for local-only.
TAILSCALE_IP=127.0.0.1

# ── pgAdmin ──
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin

# ── Application ──
DATABASE_URL=postgresql://pfs:CHANGE_ME@127.0.0.1:5432/personal_finance

# ── SEC EDGAR ──
SEC_USER_AGENT=PersonalFinanceApp your_email@example.com

# ── Alpha Vantage ──
ALPHA_VANTAGE_KEY=
