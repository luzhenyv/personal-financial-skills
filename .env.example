# ============================================
# Personal Financial Skills - Environment Config
# ============================================
# Copy to .env and fill in your values.
# See pfs/config.py Settings class for all fields and defaults.

# ── Database ──────────────────────────────────────────────
# SQLite (default — no setup needed)
DATABASE_URL=sqlite:///./data/personal_finance.db
# PostgreSQL (uncomment for production / Docker)
# DATABASE_URL=postgresql://pfs:CHANGE_ME@localhost:5432/personal_finance

# ── SEC EDGAR API (required) ──────────────────────────────
# Must include your name and email per SEC fair-access policy.
SEC_USER_AGENT=YourName your_email@example.com

# ── Alpha Vantage (optional — free tier: 25 req/day) ─────
ALPHA_VANTAGE_KEY=

# ── FRED API (optional — macro data) ─────────────────────
FRED_API_KEY=

# ── App ───────────────────────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=./data
CORS_ORIGINS=http://localhost:8501
